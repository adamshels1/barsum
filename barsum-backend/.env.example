# Server
PORT=3010

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=barsum

# JWT
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3011

# Minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9100
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Mailgun (SMTP)
SMTP_HOST=smtp.eu.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@your-domain.com
SMTP_PASSWORD=your-mailgun-smtp-password
SMTP_FROM="Barsum <noreply@barsum.kz>"

# Telegram-уведомления (один бот в супергруппе с топиками)
# TELEGRAM_ENABLED=true включает отправку (на dev держите false)
TELEGRAM_ENABLED=false
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# ID супергруппы (обязательно с включёнными «Темами»), формат -100...
TELEGRAM_CHAT_ID=
# message_thread_id каждого топика (целые числа)
TELEGRAM_TOPIC_REGISTRATIONS=
TELEGRAM_TOPIC_PAYMENTS=
TELEGRAM_TOPIC_OTHER=
TELEGRAM_TOPIC_ERRORS=
